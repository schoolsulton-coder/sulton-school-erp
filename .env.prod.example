# ============================================================
#  Sulton School ERP — PRODUCTION env
#  Nusxa oling:  cp .env.prod.example .env   (repo ildizida)
#  Bu fayl HAM compose ${...} interpolatsiyasi, HAM backend env_file uchun.
#  ⚠️ Barcha CHANGE_ME larni kuchli, tasodifiy qiymatlarga almashtiring.
# ============================================================

# ----- Domen -----
DOMAIN=erp.maktab.uz
FRONTEND_URL=https://erp.maktab.uz

# ----- Postgres (compose DATABASE_URL ni shundan quradi) -----
POSTGRES_PASSWORD=CHANGE_ME_kuchli_db_paroli

# ----- MinIO (fayl saqlash) -----
MINIO_ROOT_USER=sulton
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_paroli

# ----- Backend -----
NODE_ENV=production
PORT=4000

# JWT — uzun tasodifiy satrlar (masalan: openssl rand -hex 32)
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_32+_belgilar
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_32+_belgilar
JWT_REFRESH_TTL=7d

# ----- Telegram bot (ixtiyoriy) -----
TELEGRAM_BOT_TOKEN=

# ----- SMS / Eskiz.uz (ixtiyoriy) -----
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# ----- Storage (MinIO) — kelajakdagi fayl yuklash uchun -----
# ⚠️ Root (MINIO_ROOT_*) kalitini ilovaga BERMANG. Birinchi startdan so'ng
#    bucketga cheklangan alohida service-account yarating:
#      mc alias set m http://localhost:9000 sulton <root_parol>
#      mc admin user svcacct add m sulton   # access/secret key beradi
#    va quyidagi S3_ACCESS_KEY / S3_SECRET_KEY ga o'shani yozing.
S3_ENDPOINT=http://minio:9000
S3_BUCKET=sulton-school
S3_ACCESS_KEY=CHANGE_ME_scoped_access_key
S3_SECRET_KEY=CHANGE_ME_scoped_secret_key

# ----- E-maktab (ixtiyoriy) -----
ESMAKTAB_API_URL=
ESMAKTAB_API_KEY=

# ----- Birinchi seed uchun admin -----
ADMIN_PHONE=+998990000000
ADMIN_PASSWORD=CHANGE_ME_admin_paroli

# ----- CI/CD (GitHub Actions + GHCR) — docker-compose.deploy.yml uchun -----
# GHCR owner (GitHub foydalanuvchi/tashkilot nomi, ALBATTA kichik harflarda).
# Eslatma: avto-deploy (deploy.yml) bu qiymatni to'g'ri lowercase owner va aniq
# commit-sha bilan avtomatik ustidan yozadi — pastdagi faqat qo'lda birinchi
# `up` uchun kerak.
IMAGE_PREFIX=ghcr.io/CHANGE_ME_owner_kichik_harf
IMAGE_TAG=latest

# Eslatma: DATABASE_URL va REDIS_HOST ni qo'lda yozmang —
# ularni compose fayllari xizmat nomlari bilan avtomatik beradi.
# IMAGE_PREFIX faqat docker-compose.deploy.yml (CI/CD) uchun kerak;
# qo'lda build qilsangiz (docker-compose.prod.yml) u shart emas.
