# ===== Sulton School ERP — backend production env =====
# Serverda nusxa oling:  cp .env.production.example .env  va qiymatlarni to'ldiring

NODE_ENV=production
PORT=4000

APP_URL=https://erpsultonschool.uz
FRONTEND_URL=https://erpsultonschool.uz

# PostgreSQL — parolni O'ZINGIZNIKIGA almashtiring
DATABASE_URL=postgresql://sulton:DB_PAROLNI_ALMASHTIRING@localhost:5432/sulton_school?schema=public

# JWT — har birini `openssl rand -hex 32` bilan yarating
JWT_ACCESS_SECRET=UZUN_TASODIFIY_SATR_1
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=UZUN_TASODIFIY_SATR_2
JWT_REFRESH_TTL=7d

# Telegram bot (long-polling — webhook shart emas).
# DIQQAT: bir token bilan bir vaqtda faqat BITTA server ishlashi kerak (aks holda 409).
# Prod uchun alohida bot ochish tavsiya etiladi.
TELEGRAM_BOT_TOKEN=

# Birinchi superadmin (seed yaratadi)
ADMIN_PHONE=+998990000000
ADMIN_PASSWORD=KUCHLI_PAROL_ALMASHTIRING
